# ── Haldia Cloud Kitchen — Backend environment variables ────────────────────
# Copy to ".env" for local dev, or set these in Render's "Environment" tab.

# ── Core (REQUIRED) ─────────────────────────────────────────────────────────
NODE_ENV=production
# PORT is provided automatically by Render — do NOT set it there.
# For local dev you may uncomment:
# PORT=5000
MONGO_URI=your_mongodb_atlas_connection_string
JWT_SECRET=your_long_random_secret

# Public URL of the frontend — used to build password-reset links in emails.
# NO trailing slash. e.g. https://haldiacloudkitchen.in
CLIENT_URL=https://haldiacloudkitchen.in

# ── Image upload (Cloudinary) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Payments (Razorpay) ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=orders@yourdomain.com

# ── Push notifications (OneSignal) ──────────────────────────────────────────
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key
ONESIGNAL_ADMIN_CHANNEL_ID=your_admin_channel_id
ONESIGNAL_CHAT_CHANNEL_ID=your_chat_channel_id
ONESIGNAL_ORDER_CHANNEL_ID=your_order_channel_id

# ── Restaurant location (delivery distance calc) ────────────────────────────
RESTAURANT_LAT=22.0333
RESTAURANT_LNG=88.0600

# ── WhatsApp ────────────────────────────────────────────────────────────────
# Currently DISABLED in code (puppeteer/Chrome too heavy for low-memory hosting).
# No env needed unless you re-enable it in server.js + orderController.js.
