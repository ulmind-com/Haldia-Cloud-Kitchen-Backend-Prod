<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <style>
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f4f5f7;
            color: #282c3f;
        }

        .container {
            max-width: 600px;
            margin: 20px auto;
            background-color: #ffffff;
            border: 1px solid #e0e0e0;
        }

        .header {
            background-color: #ffffff;
            padding: 20px;
            text-align: center;
            border-bottom: 2px solid #60b246;
            /* Green for Accepted */
        }

        .header img.logo {
            max-height: 50px;
        }

        .content {
            padding: 30px;
        }

        .greeting {
            font-size: 16px;
            margin-bottom: 20px;
        }

        .order-meta {
            margin-bottom: 30px;
            font-size: 14px;
            color: #686b78;
        }

        .item-list {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 25px;
        }

        .item-list td {
            padding: 12px 0;
            border-bottom: 1px dashed #d4d5d9;
            vertical-align: top;
        }

        .item-img {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 4px;
            margin-right: 15px;
        }

        .item-details {
            display: flex;
            align-items: center;
        }

        .item-name {
            font-size: 15px;
            font-weight: 500;
            color: #282c3f;
        }

        .item-qty {
            font-size: 12px;
            color: #93959f;
            margin-top: 4px;
        }

        .price {
            text-align: right;
            white-space: nowrap;
            font-weight: 500;
        }

        .billing-summary {
            background-color: #f9f9f9;
            padding: 20px;
        }

        .billing-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-size: 14px;
            color: #686b78;
        }

        .billing-row.total {
            border-top: 1px solid #d4d5d9;
            margin-top: 15px;
            padding-top: 15px;
            font-weight: 700;
            font-size: 16px;
            color: #282c3f;
        }

        .footer {
            background-color: #f4f5f7;
            padding: 20px;
            text-align: center;
            font-size: 11px;
            color: #93959f;
            border-top: 1px solid #e0e0e0;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="header">
            {{#if logo}}<img src="{{logo}}" alt="{{restaurantName}}" class="logo">{{/if}}
        </div>
        <div class="content">
            <div class="greeting">Hi {{customerName}},</div>
            <p style="font-size: 14px; color: #535665; line-height: 1.6;">
                Great news! <strong>{{restaurantName}}</strong> has accepted your order <strong>{{orderId}}</strong> and
                is preparing your food. 👨‍🍳
            </p>
            <div class="order-meta">
                <p><strong>Date:</strong> {{orderDate}}</p>
                <p><strong>Status:</strong> <span style="color: #60b246; font-weight: 700;">ACCEPTED</span></p>
            </div>

            <div
                style="font-size: 13px; text-transform: uppercase; color: #7e808c; margin-bottom: 15px; font-weight: 600;">
                Items in Preparation</div>
            <table class="item-list">
                {{#each items}}
                <tr>
                    <td>
                        <div class="item-details">
                            {{#if this.image}}<img src="{{this.image}}" class="item-img">{{/if}}
                            <div>
                                <div class="item-name">{{this.name}}</div>
                                <div class="item-qty">Qty: {{this.quantity}}</div>
                            </div>
                        </div>
                    </td>
                    <td class="price">₹{{this.total}}</td>
                </tr>
                {{/each}}
            </table>

            <div class="billing-summary">
                <div class="billing-row"><span>Order Total</span><span>₹{{total}}</span></div>
            </div>

            <div style="text-align: center; margin-top: 20px; color: #777; font-style: italic;">
                It will be out for delivery shortly! 🛵
            </div>
        </div>
        <div class="footer">
            <p>&copy; {{year}} {{restaurantName}}.</p>
            <p>{{restaurantAddress}}</p>
        </div>
    </div>
</body>

</html>